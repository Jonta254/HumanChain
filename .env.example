# World Developer Portal Mini App ID.
# Use the same value for APP_ID server-side and NEXT_PUBLIC_WORLD_APP_ID client-side.
APP_ID=app_fd34958eed3f67a6710d76c46d261f77
NEXT_PUBLIC_WORLD_APP_ID=app_fd34958eed3f67a6710d76c46d261f77

# Public deployment URL used by Next metadata and World App previews.
NEXT_PUBLIC_APP_URL=

# Developer Portal API key used by server routes to verify payments and send notifications.
# Enable notifications in the World Developer Portal Advanced settings too.
# HumanChain notification sectors: inbox, marketplace, daily, stories, payments, account.
DEV_PORTAL_API_KEY=

# Pulse treasury wallet that receives WLD payments in MiniKit.pay().
NEXT_PUBLIC_PULSE_TREASURY=0x6588e8765c495a9d44e93b0293aedd7ecd6167fc

# Vercel Blob token for durable user image uploads and JSON data receipts.
BLOB_READ_WRITE_TOKEN=

# Optional backend services configured in production.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
CRON_SECRET=

# Optional treasury payout rail. World Pay receives user payments; winner payouts
# are sent by this treasury signer on World Chain when enabled.
TREASURY_PAYOUT_ENABLED=false
TREASURY_PAYOUT_PRIVATE_KEY=
WORLD_CHAIN_RPC_URL=https://worldchain-mainnet.g.alchemy.com/public

# World ID / IDKit verification config.
# RP_SIGNING_KEY is the Developer Portal signing_key and must never be exposed to the client.
WORLD_RP_ID=rp_0717c6ad5e52999e
RP_SIGNING_KEY=
