# World Developer Portal Mini App ID.
# Use the same value for APP_ID server-side and NEXT_PUBLIC_WORLD_APP_ID client-side.
APP_ID=
NEXT_PUBLIC_WORLD_APP_ID=

# Developer Portal API key used by server routes to verify payments and send notifications.
DEV_PORTAL_API_KEY=

# HumanChain treasury wallet that receives WLD payments in MiniKit.pay().
NEXT_PUBLIC_HUMANCHAIN_TREASURY=

# World ID / IDKit verification config. Add these when one-human-one-action proof is enabled.
WORLD_RP_ID=
WORLD_RP_SIGNING_SECRET=
