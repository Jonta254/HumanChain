# World Developer Portal Mini App ID.
# Use the same value for APP_ID server-side and NEXT_PUBLIC_WORLD_APP_ID client-side.
APP_ID=app_97e4c10f331dd72c24d29ba5f98e5bb7
NEXT_PUBLIC_WORLD_APP_ID=app_97e4c10f331dd72c24d29ba5f98e5bb7

# Public deployment URL used by Next metadata and World App previews.
NEXT_PUBLIC_APP_URL=https://human-chain-gamma.vercel.app

# Developer Portal API key used by server routes to verify payments and send notifications.
# Enable notifications in the World Developer Portal Advanced settings too.
# HumanChain notification sectors: inbox, marketplace, daily, stories, payments, account.
DEV_PORTAL_API_KEY=

# HumanChain treasury wallet that receives WLD payments in MiniKit.pay().
NEXT_PUBLIC_HUMANCHAIN_TREASURY=0x6588e8765c495a9d44e93b0293aedd7ecd6167fc

# Vercel Blob token for durable user image uploads and JSON data receipts.
BLOB_READ_WRITE_TOKEN=

# Future durable social data store for posts, comments, reactions, and history.
DATABASE_URL=

# World ID / IDKit verification config.
# RP_SIGNING_KEY is the Developer Portal signing key — NEVER expose to the client or commit.
# Set this in Vercel env vars (server-only, all environments).
WORLD_RP_ID=rp_11af98b36fc272da
RP_SIGNING_KEY=
